{
  "name": "smart-grocery-store",
  "version": "1.0.0",
  "description": "Smart Grocery Store - Full Stack Application",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "node server/seed.js",
    "render-build": "cd client && npm install && npx react-scripts build",
    "start": "node server/seed.js && node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "redis": "^4.6.12",
    "concurrently": "^8.2.2",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "engines": {
    "node": "18.x"
  }
}
